# ============================================================
# Frontend (Vite) environment variables
# Copy this file to ".env" and adjust the values as needed.
# Only variables prefixed with VITE_ are exposed to the client.
# ============================================================

# Dev server port for the Vite frontend
VITE_PORT=5173

# Base URL for API calls from the frontend.
# Leave empty to use the Vite dev proxy (recommended in development).
# In production set it to your backend URL, e.g. https://api.example.com
VITE_API_BASE_URL=

# Target the Vite dev proxy forwards /api requests to (backend address)
VITE_DEV_PROXY_TARGET=http://localhost:4000
