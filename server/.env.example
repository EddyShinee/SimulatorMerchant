# ============================================================
# Backend (Express) environment variables
# Copy this file to "server/.env" and adjust the values.
# ============================================================

# Port the Express API server listens on
PORT=4000

# Secret used to sign JWT auth tokens. CHANGE THIS in production!
JWT_SECRET=change-this-to-a-long-random-secret-string

# How long an auth token stays valid (e.g. 1h, 12h, 7d)
JWT_EXPIRES_IN=12h

# Number of bcrypt salt rounds for password hashing
BCRYPT_SALT_ROUNDS=10

# Path (relative to the server folder) to the CSV file that stores users
USERS_CSV_PATH=data/users.csv

# Comma-separated list of allowed CORS origins (frontend URLs).
# Use * to allow any origin (fine for local development).
CORS_ORIGIN=http://localhost:5173

# SPA origin for payment callback redirects (local dev: Vite on 5173, API on 4000)
DEV_FRONTEND_URL=http://localhost:5173
